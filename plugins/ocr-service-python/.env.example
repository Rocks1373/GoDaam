# Bind (default 8090 for nginx proxy /ocr/)
HOST=0.0.0.0
PORT=8090

# Paths relative to app/ or absolute
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# Optional: restrict CORS (comma-separated origins). Empty = allow common local + *
# CORS_ORIGINS=http://localhost:5173,https://godam.divadivya.cloud

# Browser fetch() base for API calls in index.html.
# Direct uvicorn: /api/ocr
# Behind nginx "location /ocr/ { proxy_pass http://127.0.0.1:8090/; }": use /ocr/api/ocr
PUBLIC_API_PREFIX=/api/ocr
