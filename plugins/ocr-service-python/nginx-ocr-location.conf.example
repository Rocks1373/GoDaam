# Example: serve the Python OCR UI + API under https://your-domain/ocr/
# Place inside your server { } block. OCR service listens on 127.0.0.1:8090
#
# In plugins/ocr-service-python/.env set:
#   PUBLIC_API_PREFIX=/ocr/api/ocr
# so browser calls /ocr/api/ocr/upload → proxied to http://127.0.0.1:8090/api/ocr/upload

location /ocr/ {
    proxy_pass http://127.0.0.1:8090/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    client_max_body_size 35m;
}
