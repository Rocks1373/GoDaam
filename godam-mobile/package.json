{
  "name": "godam-mobile",
  "version": "1.0.2",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --port 8090",
    "start:emu-android": "bash ../scripts/expo-start-android-emulator.sh",
    "android": "expo run:android",
    "android:release-apk": "NODE_ENV=production bash -c 'cd android && ./gradlew assembleRelease'",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:apk:preview": "eas build --platform android --profile preview",
    "eas:apk:production": "eas build --platform android --profile production",
    "eas:login": "eas login",
    "eas:init": "eas init"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "axios": "^1.15.2",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-text-extractor": "^2.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
