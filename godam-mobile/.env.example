# Copy to `.env` in this folder (Expo loads it automatically).
#
# Release APKs: users enter Backend API Base URL on first launch (Configuration screen);
# it is stored as `backend_api_url` in AsyncStorage. EXPO_PUBLIC_API_URL is optional and
# does not skip Configuration — only affects dev/constants if you read extra elsewhere.

# Optional — dev only; enter the same value in the app Configuration screen for real use:
# EXPO_PUBLIC_API_URL=https://your-domain.com

# Must match server MOBILE_APP_API_KEY (optional — omit on both sides to disable this check).
# EXPO_PUBLIC_MOBILE_API_KEY=
