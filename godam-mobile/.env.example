# Copy to `.env` in this folder (Expo loads it automatically).
# Backend must be running (e.g. ./dev.sh from repo root → API on port 3001).

# iOS Simulator or Expo Web on the same Mac:
EXPO_PUBLIC_API_URL=http://localhost:3001

# Android Emulator — use localhost or http://127.0.0.1:3001; the app rewrites the host
# to 10.0.2.2 on emulators (see src/api/client.ts). Or use the one-shot script from repo root:
#   npm run android:emu

# Physical phone (same Wi‑Fi as your computer). Replace with your Mac’s LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.XXX:3001

# Production (Hostinger example — same host as web; nginx serves app on :8080 here):
# EXPO_PUBLIC_API_URL=http://72.61.245.23:8080

# Must match server MOBILE_APP_API_KEY (optional — omit on both sides to disable this check).
# EXPO_PUBLIC_MOBILE_API_KEY=
