# Copy to `.env` in this folder (Expo loads it automatically).
#
# Default API host is the production VPS (see baseline-api.js) baked into the bundle unless you set
# EXPO_PUBLIC_API_URL below. First launch still uses Configuration unless a URL was auto-saved from that default.

# Local dev — point at your machine (overrides VPS baseline in app.config + getDefaultApiBaseUrl):
# EXPO_PUBLIC_API_URL=http://127.0.0.1:3001

# Optional — same as default VPS if unset; set explicitly for a different production host:
# EXPO_PUBLIC_API_URL=https://godam.divadivya.cloud

# Optional UTF-8 base64 (decoded in app.config.js at build time). Use instead of plaintext above
# when generating test builds: scripts/test-mobile/setup-from-vps.sh
# EXPO_PUBLIC_API_URL_B64=
# EXPO_PUBLIC_MOBILE_API_KEY_B64=

# Must match server MOBILE_APP_API_KEY (optional — omit on both sides to disable this check).
# EXPO_PUBLIC_MOBILE_API_KEY=
