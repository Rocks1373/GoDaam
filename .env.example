# Used by docker-compose (copy to `.env` on the server — never commit `.env`)

# Host port published for nginx `web` (default 80). On Hostinger when Traefik uses :80, use 8080.
WEB_HOST_PORT=80

JWT_SECRET=replace-with-long-random-string

# Browser origin(s) allowed by the API when not using same-host nginx (mobile/native still OK).
# For Docker web+api behind one nginx, same-origin requests often omit Origin; backend allows that.
# Wildcard CORS (mobile/testing): use * or set CORS_ALLOW_ALL=1 in server.js logic.
# Set explicitly if you hit CORS issues: https://yourdomain.com
CORS_ORIGIN=*

# Optional explicit flag (see backend/server.js buildCorsOptions).
# CORS_ALLOW_ALL=1

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# Optional: native app gate — must match EXPO_PUBLIC_MOBILE_API_KEY in the Expo build.
# Generate: openssl rand -hex 32
# MOBILE_APP_API_KEY=

# Optional seeds / tuning (see backend README or db.js)
# GODAM_SEED_DEMO_DATA=0
