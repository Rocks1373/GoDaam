# Copy to `.env` on the server (never commit `.env`)

JWT_SECRET=replace-with-long-random-string

# Browser origins allowed by the API when requests are cross-origin (mobile/native flows still OK).
# When nginx serves the SPA and proxies `/api` to Node on the same host, same-origin often omits Origin;
# backend still allows typical cases — set explicitly if you hit CORS: https://yourdomain.com
# Wildcard / testing: *
CORS_ORIGIN=*

# Optional explicit flag (see backend/server.js buildCorsOptions).
# CORS_ALLOW_ALL=1

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# --- AI Admin Assistant (Python plugin) ---
# Run the Python service in ai_plugin/ and point backend to it.
AI_PLUGIN_URL=http://127.0.0.1:8011
AI_PLUGIN_SHARED_SECRET=change-me

# LLM provider configuration (used by ai_plugin)
AI_PROVIDER=openai
AI_MODEL=gpt-4.1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Safety
AUTO_FIX=false

# --- GoDam 1.0 Streamlit plugin (Python) + Node ---
# Start Streamlit as a child of the Node process (./dev.sh / npm run dev:web:huawei / production if unset below).
# HUAWEI_GODAM_STREAMLIT_AUTOSTART=1
# On production, omit Streamlit autostart unless you want Python on the same box:
# HUAWEI_GODAM_STREAMLIT_DISABLE_PRODUCTION=1
# Cookie path + Streamlit --server.baseUrlPath (must match frontend iframe / Vite proxy).
# HUAWEI_GODAM_STREAMLIT_BASE_PATH=huawei-godam-app
# HUAWEI_GODAM_STREAMLIT_PORT=8501
# Public URL Streamlit uses for links (prod): https://your.domain/huawei-godam-app
# STREAMLIT_PUBLIC_URL=
# Force Secure cookies when not using NODE_ENV=production (e.g. HTTPS reverse proxy).
# COOKIE_SECURE=1

# Optional native app gate — must match EXPO_PUBLIC_MOBILE_API_KEY in the Expo build.
# Generate: openssl rand -hex 32
# MOBILE_APP_API_KEY=

# Admin-only APK download (/api/admin/mobile-app). Default file: backend/uploads/mobile/GoDam.apk
# (created by scripts/build-godam-android-release-apk.sh on the build host, then rsync to the server).
# MOBILE_APP_APK_PATH=

# Shown on the Mobile Apps admin page (documentation only; set to match the URL baked into the APK).
# MOBILE_APP_EMBEDDED_API_BASE=https://your.domain

# Optional seeds / tuning (see backend README or db.js)
# GODAM_SEED_DEMO_DATA=0
