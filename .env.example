# Copy to `backend/.env` (local dev) or `.env` on the server (never commit real `.env` files).
#
# Required — must not be empty and must not match known placeholders (see backend/middleware/auth.js).
# Generate: openssl rand -hex 64
JWT_SECRET=

# --- Auth / rate limits ---
# AUTH_LIMIT_MAX=10
# AUTH_LIMIT_WINDOW_MS=900000
# AUTH_USER_LIMIT_MAX=30
# AUTH_USER_LIMIT_WINDOW_MS=900000
# AUTH_LOCK_MAX_ATTEMPTS=8
# AUTH_LOCK_MINUTES=30
# LOG_LEVEL=info

# --- Main warehouse DB (GoDam) — PostgreSQL required (backend/db.js) ---
# Local ./dev.sh defaults to PostgreSQL + Docker (see docker-compose.godam-postgres.yml).
#
DB_TYPE=postgres
DATABASE_URL=postgresql://godam_user:godam_dev_local@127.0.0.1:5432/godam_db
# PG_POOL_MAX=25
# PG_CONNECTION_TIMEOUT_MS=10000
# PG_IDLE_TIMEOUT_MS=30000
# Managed Postgres / TLS: add query params to DATABASE_URL, e.g.
#   ?sslmode=require
# or set PGSSLMODE=require (see node-postgres / libpq docs).
#
# One-time copy from a legacy SQLite warehouse.db (optional; keeps the .db file):
#   cd backend && npm run migrate:sqlite-to-pg
# Or let ./dev.sh run pg-bootstrap when PG is empty and backend/warehouse.db exists.

# Browser origins allowed by the API when requests are cross-origin (mobile/native flows still OK).
# When nginx serves the SPA and proxies `/api` to Node on the same host, same-origin often omits Origin;
# backend still allows typical cases — set explicitly if you hit CORS: https://yourdomain.com
# Wildcard / testing: *
CORS_ORIGIN=*

# Optional explicit flag (see backend/server.js buildCorsOptions).
# CORS_ALLOW_ALL=1

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# --- OCR (external HTTP service, FastAPI-compatible /api/ocr/*) ---
# Required for POST /api/mobile/ocr/image when using server-side OCR. Example: http://127.0.0.1:8090
OCR_PYTHON_SERVICE_URL=http://127.0.0.1:8090

# --- AI microservice (Python FastAPI in ai-service/) — Node proxies /api/ai/* only ---
AI_SERVICE_URL=http://127.0.0.1:8020
AI_SERVICE_SHARED_SECRET=change-me

# Public customer-service portal (/customer-service) — backend /api/customer-service/*
CUSTOMER_SERVICE_USERNAME=customer
CUSTOMER_SERVICE_PASSWORD=change-this-customer-password
# CUSTOMER_SERVICE_JWT_SECRET=optional-separate-secret
# Frontend: set true only for offline UI demo (no backend/AI)
# VITE_CUSTOMER_SERVICE_DEMO=false
# Legacy alias (same service):
AI_PLUGIN_URL=http://127.0.0.1:8020
AI_PLUGIN_SHARED_SECRET=change-me

# Configured in /etc/godaam/ai-service.env on VPS (NOT read by Node):
# AI_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:1.5b

# Safety
AUTO_FIX=false

# --- GoDam 1.0 Streamlit plugin (Python) + Node ---
# Start Streamlit as a child of the Node process (./dev.sh / npm run dev:web:huawei / production if unset below).
# HUAWEI_GODAM_STREAMLIT_AUTOSTART=1
# On production, omit Streamlit autostart unless you want Python on the same box:
# HUAWEI_GODAM_STREAMLIT_DISABLE_PRODUCTION=1
# Cookie path + Streamlit --server.baseUrlPath (must match frontend iframe / Vite proxy).
# HUAWEI_GODAM_STREAMLIT_BASE_PATH=huawei-godam-app
# HUAWEI_GODAM_STREAMLIT_PORT=8501
# Public URL Streamlit uses for links (prod): https://your.domain/huawei-godam-app
# STREAMLIT_PUBLIC_URL=
# Force Secure cookies when not using NODE_ENV=production (e.g. HTTPS reverse proxy).
# COOKIE_SECURE=1

# Optional native app gate — must match EXPO_PUBLIC_MOBILE_API_KEY in the Expo build.
# Generate: openssl rand -hex 32
# MOBILE_APP_API_KEY=

# Admin APK download (/api/admin/mobile-app) and public staff download (/api/mobile-app/apk).
# Default file: backend/uploads/mobile/GoDam.apk
# (created by scripts/build-android-apk.sh on the build host, then rsync to the server).
# MOBILE_APP_APK_PATH=

# Shown on the Mobile Apps admin page (documentation only; set to match the URL baked into the APK).
# MOBILE_APP_EMBEDDED_API_BASE=https://your.domain

# --- Cloud document storage (Sales Order folders on Google Drive) ---
# STORAGE_PROVIDER=GOOGLE_DRIVE
# GOOGLE_DRIVE_AUTH_MODE=oauth
# OAuth Web client (same project as Drive API). Connect once in Admin → Google Drive.
# GOOGLE_DRIVE_OAUTH_CLIENT_ID=your-id.apps.googleusercontent.com
# GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=your-client-secret
# Must match Google Cloud Console → OAuth client → Authorized redirect URIs (character-for-character):
# GOOGLE_DRIVE_OAUTH_REDIRECT_URI=http://localhost:3001/api/google/oauth/callback
# FRONTEND_URL=http://localhost:5173
# Folder in connected user's My Drive (copy from Drive URL):
# GOOGLE_DRIVE_ROOT_FOLDER_ID=174hT47E4QMfTekmpgTi-5xNVUtD0gOHJ
# Optional legacy service account (GOOGLE_DRIVE_AUTH_MODE=service_account):
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON_PATH=/absolute/path/to/service-account.json

# Google Sign-In (OAuth 2.0 Web client — public ID, not a secret)
# GOOGLE_WEB_CLIENT_ID=your-id.apps.googleusercontent.com
# GOOGLE_ANDROID_CLIENT_ID=your-android-id.apps.googleusercontent.com

# Optional seeds / tuning (see backend README or db.js)
# GODAM_SEED_DEMO_DATA=0
