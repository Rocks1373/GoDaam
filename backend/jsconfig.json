{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "checkJs": false
  },
  "include": [
    "*.js",
    "middleware/**/*.js",
    "models/**/*.js",
    "routes/**/*.js",
    "scripts/**/*.js",
    "services/**/*.js",
    "utils/**/*.js"
  ],
  "exclude": ["node_modules", "uploads"]
}
