## Frontend (Vite) environment variables
#
# Copy to `frontend/.env.local` (recommended) or `frontend/.env`
# Vite only exposes variables prefixed with `VITE_`.

# Optional: GoDam 1.0 hosted outside this app (full URL). When set, sidebar "GoDam 1.0" opens this URL in a new tab (no proxy cookie).
# If unset, the link grants proxy access and opens `/huawei-godam-app/` on this origin in a new tab (Python Streamlit behind Node/nginx).
# Example: https://godam.example.com
VITE_GODAM_1_EXTERNAL_URL=

# Optional OCR tool link (admin sidebar; opens in new tab)
VITE_OCR_TOOL_URL=

# Proxy path segment for Streamlit when using built-in hosting (must match backend HUAWEI_GODAM_STREAMLIT_BASE_PATH).
# VITE_HUAWEI_GODAM_STREAMLIT_BASE=huawei-godam-app

