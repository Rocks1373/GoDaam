# Copy to /etc/godaam/backend.env on the VPS (chmod 600).
# Used by systemd: godaam-backend.service

NODE_ENV=production
PORT=3001

# Required — generate a long random string
JWT_SECRET=change-me

# Comma-separated browser origins allowed to call the API (your HTTPS site)
CORS_ORIGIN=https://godam.divadivya.cloud

# Optional — match mobile app if you use API key gate
# MOBILE_APP_API_KEY=

# Optional — Huawei: Streamlit co-managed by Node on the VPS (after npm run setup:huawei-godam + GoDam-1.0 present)
# HUAWEI_GODAM_STREAMLIT_AUTOSTART=1
# HUAWEI_GODAM_STREAMLIT_BASE_PATH=huawei-godam-app
# HUAWEI_GODAM_STREAMLIT_PORT=8501
#
# Alternative: run Streamlit under systemd separately and point the API at it:
# HUAWEI_GODAM_URL=http://127.0.0.1:8501
