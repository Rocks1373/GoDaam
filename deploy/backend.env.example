# Copy to /etc/godaam/backend.env on the VPS (chmod 600).
# Used by systemd: godaam-backend.service

NODE_ENV=production
PORT=3001

# Required — main warehouse API (see backend/db.js)
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/godam_db
DB_TYPE=postgres
# PG_POOL_MAX=25
# PG_CONNECTION_TIMEOUT_MS=10000
# PG_IDLE_TIMEOUT_MS=30000

# Required — generate a long random string
JWT_SECRET=change-me

# Comma-separated browser origins allowed to call the API (your HTTPS site)
CORS_ORIGIN=https://godam.divadivya.cloud

# Optional — match mobile app if you use API key gate
# MOBILE_APP_API_KEY=

# Google Sign-In (OAuth 2.0 client IDs — public, not secrets)
# GOOGLE_WEB_CLIENT_ID=your-web-id.apps.googleusercontent.com
# GOOGLE_ANDROID_CLIENT_ID=your-android-id.apps.googleusercontent.com
# GOOGLE_IOS_CLIENT_ID=

# Frontend build on VPS must set VITE_GOOGLE_WEB_CLIENT_ID (same as GOOGLE_WEB_CLIENT_ID) before npm run build

# --- Cloud document storage (Sales Order folders on Google Drive) ---
# STORAGE_PROVIDER=GOOGLE_DRIVE
# GOOGLE_DRIVE_AUTH_MODE=oauth
# OAuth Web client (project godaam-496511) — connect in Admin → Google Drive
# GOOGLE_DRIVE_OAUTH_CLIENT_ID=863056243525-....apps.googleusercontent.com
# GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=GOCSPX-...
# GOOGLE_DRIVE_OAUTH_REDIRECT_URI=https://YOUR-API-HOST/api/storage/google-oauth/callback
# FRONTEND_URL=https://godam.divadivya.cloud
# Root folder in the connected user's My Drive (unchanged):
# GOOGLE_DRIVE_ROOT_FOLDER_ID=174hT47E4QMfTekmpgTi-5xNVUtD0gOHJ
#
# Future (inactive unless STORAGE_PROVIDER=ONEDRIVE):
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_TENANT_ID=
# ONEDRIVE_CLIENT_SECRET=
# ONEDRIVE_ROOT_FOLDER_ID=

# Optional — Huawei: Streamlit co-managed by Node on the VPS (after npm run setup:huawei-godam + **plugins/GoDam-1.0** present)
# HUAWEI_GODAM_STREAMLIT_AUTOSTART=1
# HUAWEI_GODAM_STREAMLIT_BASE_PATH=huawei-godam-app
# HUAWEI_GODAM_STREAMLIT_PORT=8501
#
# Alternative: run Streamlit under systemd separately and point the API at it:
# HUAWEI_GODAM_URL=http://127.0.0.1:8501

# --- AI microservice (Gemini Flash + Ollama qwen2.5:1.5b fallback) ---
# Setup: sudo bash /opt/godaam/deploy/vps/setup-ai-service-vps.sh
# Or: bash deploy/vps/rsync-to-godaam-vps.sh --deploy --ai
# AI_SERVICE_URL=http://127.0.0.1:8020
# AI_SERVICE_SHARED_SECRET=must-match-/etc/godaam/ai-service.env
# GEMINI_API_KEY goes in /etc/godaam/ai-service.env (not here)

# Customer-service portal (public /customer-service page)
# CUSTOMER_SERVICE_USERNAME=customer
# CUSTOMER_SERVICE_PASSWORD=change-me-strong
# CUSTOMER_SERVICE_JWT_SECRET=optional-dedicated-jwt-secret

# Optional — Local Scanner Agent (POST /api/scanner-agent/sales-order-documents/upload with X-Scanner-Agent-Token)
# Generate: openssl rand -hex 32
# SCANNER_AGENT_TOKEN=
# users.id for uploaded_by / checklist (use a dedicated service user)
# SCANNER_AGENT_USER_ID=1
# Optional: restrict warehouses (comma-separated). If unset, token is the only gate.
# SCANNER_AGENT_WAREHOUSE_IDS=1,2
