[Unit]
Description=GoDaam warehouse API (Node)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/godaam/backend
Environment=NODE_ENV=production
EnvironmentFile=-/etc/godaam/backend.env
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
