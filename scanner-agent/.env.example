GODAM_API_BASE=https://your-godam-host.example.com/api
SCANNER_AGENT_TOKEN=replace-with-openssl-rand-hex-32

# Listen port (browser default in frontend: http://127.0.0.1:38471)
# GODAM_SCANNER_LISTEN_PORT=38471

# Shell command that writes a PDF. Use {output} as placeholder for file path.
# GODAM_SCAN_COMMAND=your-scanner-cli-here --out {output}

# Dev only: one-page blank PDF if no physical scanner
# GODAM_ALLOW_MOCK_SCAN=1
